<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<TabPane prefHeight="500.0" prefWidth="900.0" tabClosingPolicy="UNAVAILABLE"
         xmlns="http://javafx.com/javafx/26"
         xmlns:fx="http://javafx.com/fxml/1"
         fx:controller="com.library.controllers.MainController">
  <tabs>

    <Tab text="Номын сан">
      <content>
        <AnchorPane>
          <SplitPane dividerPositions="0.3"
                     AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
                     AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <items>
              <AnchorPane>
                <VBox spacing="10"
                      AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
                      AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
                  <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                  <Label style="-fx-font-weight:bold;-fx-font-size:14;" text="Номын бүртгэл"/>
                  <Label text="Номын нэр:"/>
                  <TextField fx:id="txtBookName" promptText="Номын нэр"/>
                  <Label text="Зохиолч:"/>
                  <TextField fx:id="txtAuthor" promptText="Зохиолч"/>
                  <Label text="ISBN:"/>
                  <TextField fx:id="txtIsbn" promptText="ISBN"/>
                  <Label text="Тоо ширхэг:"/>
                  <TextField fx:id="txtQty" promptText="Тоо ширхэг"/>
                  <Button fx:id="btnAddBook" text="Нэмэх" onAction="#onAddBookClick"
                          maxWidth="Infinity"
                          style="-fx-background-color:#4CAF50;-fx-text-fill:white;"/>
                </VBox>
              </AnchorPane>
              <AnchorPane>
                <VBox spacing="10"
                      AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
                      AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
                  <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                  <HBox spacing="10">
                    <Label text="Хайх:"/>
                    <TextField fx:id="txtBookResearch" promptText="Хайх..." HBox.hgrow="ALWAYS"/>
                  </HBox>
                  <TableView fx:id="tableBook" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                      <TableColumn fx:id="colTitle" text="Номын нэр" prefWidth="150"/>
                      <TableColumn fx:id="colAuthor" text="Зохиолч" prefWidth="100"/>
                      <TableColumn fx:id="colIsbn" text="ISBN" prefWidth="90"/>
                      <TableColumn fx:id="colQty" text="Тоо ширхэг" prefWidth="90"/>
                      <TableColumn fx:id="colAv" text="Боломжит үлдэгдэл" prefWidth="130"/>
                    </columns>
                  </TableView>
                </VBox>
              </AnchorPane>
            </items>
          </SplitPane>
        </AnchorPane>
      </content>
    </Tab>

    <Tab text="Уншигч">
      <content>
        <AnchorPane>
          <SplitPane dividerPositions="0.3"
                     AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
                     AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <items>
              <AnchorPane>
                <VBox spacing="10"
                      AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
                      AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
                  <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                  <Label style="-fx-font-weight:bold;-fx-font-size:14;" text="Уншигчийн бүртгэл"/>
                  <Label text="Нэр:"/>
                  <TextField fx:id="txtMemberName" promptText="Нэр"/>
                  <Label text="Овог:"/>
                  <TextField fx:id="txtSurname" promptText="Овог"/>
                  <Label text="Утас:"/>
                  <TextField fx:id="txtPhone" promptText="Утас"/>
                  <Label text="Email:"/>
                  <TextField fx:id="txtEmail" promptText="Email"/>
                  <Button text="Нэмэх" onAction="#onAddMemberClick"
                          maxWidth="Infinity"
                          style="-fx-background-color:#4CAF50;-fx-text-fill:white;"/>
                </VBox>
              </AnchorPane>
              <AnchorPane>
                <VBox spacing="10"
                      AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
                      AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
                  <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                  <HBox spacing="10">
                    <Label text="Хайх:"/>
                    <TextField fx:id="txtMemberSearch" promptText="Хайх..." HBox.hgrow="ALWAYS"/>
                  </HBox>
                  <TableView fx:id="tableMember" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colMId" text="ID" prefWidth="50"/>
                      <TableColumn fx:id="colMemberName" text="Нэр" prefWidth="120"/>
                      <TableColumn fx:id="colMemberSurname" text="Овог" prefWidth="120"/>
                      <TableColumn fx:id="colPhone" text="Утас" prefWidth="100"/>
                      <TableColumn fx:id="colEmail" text="Email" prefWidth="130"/>
                    </columns>
                  </TableView>
                </VBox>
              </AnchorPane>
            </items>
          </SplitPane>
        </AnchorPane>
      </content>
    </Tab>

    <Tab text="Номын түрээс">
      <content>
        <AnchorPane>
          <VBox spacing="15"
                AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
                AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT"
                  style="-fx-border-color:#cccccc;-fx-border-width:1;-fx-border-radius:5;-fx-padding:10;">
              <Button fx:id="btnRentBook" text="Ном түрээслэх" onAction="#onRentBookClick"/>
              <Button fx:id="btnReturnBook" text="Ном буцаах" onAction="#onReturnBookClick"/>
              <fx:define>
                <ToggleGroup fx:id="filterGroup"/>
              </fx:define>
              <RadioButton fx:id="radioAll" text="Бүгд" selected="true" toggleGroup="$filterGroup"/>
              <RadioButton fx:id="radioOverdue" text="Хугацаа хэтэрсэн" toggleGroup="$filterGroup"/>
            </HBox>
            <TableView fx:id="tableRental" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colRentalId" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colRentMemberName" text="Уншигч" prefWidth="150"/>
                <TableColumn fx:id="colRentBookTitle" text="Номын нэр" prefWidth="200"/>
                <TableColumn fx:id="colRentDate" text="Түрээслэсэн өдөр" prefWidth="130"/>
                <TableColumn fx:id="colReturnDate" text="Буцаах өдөр" prefWidth="120"/>
                <TableColumn fx:id="colRentalStatus" text="Төлөв" prefWidth="120"/>
              </columns>
            </TableView>
          </VBox>
        </AnchorPane>
      </content>
    </Tab>

  </tabs>
</TabPane>
